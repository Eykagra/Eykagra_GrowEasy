PORT=4000

# Primary provider: gemini or mistral (mistral recommended if Gemini quota is exhausted)
AI_PRIMARY=gemini

# Google Gemini — AIza (standard) or AQ. (auth) keys from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# Mistral — used for fallback and parallel batch load-balancing with Gemini
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

BATCH_SIZE=25
# Up to 4 batches (100 rows max per import); PARALLEL_BATCHES run at once per wave
MAX_BATCHES=4
PARALLEL_BATCHES=3
MAX_RETRIES=3

# Comma-separated allowed origins. Vercel *.vercel.app is auto-allowed.
# Example: http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Render sets PORT automatically. HOST=0.0.0.0 for cloud deploys.
HOST=0.0.0.0